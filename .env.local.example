# Supabase — required for auth + CRM data
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Aurora Solar
AURORA_SOLAR_API_KEY=
AURORA_SOLAR_TENANT_ID=
AURORA_WEBHOOK_SECRET=

# Inbound sync from goldendoorapp.com
GOLDENDOORAPP_SYNC_KEY=

# PandaDoc — document send + webhook
PANDADOC_API_KEY=
PANDADOC_WEBHOOK_SHARED_KEY=

# Server-to-server bearer token for /api/* (mobile agents, DeltaOps crew-app, etc.).
# Generate with: openssl rand -hex 32
# Additive to the Supabase cookie/session path — either is accepted.
GOLDENDOORHQ_API_KEY=

# Seed script (scripts/seed-auth-user.mjs)
SEED_USER_EMAIL=afan@goldendoorhq.com
SEED_USER_PASSWORD=
